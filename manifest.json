{
  "manifest_version": 3,
  "name": "MeetScribe — Open Source Meeting Transcriber",
  "version": "1.0.0",
  "description": "Live transcription with speaker diarization, AI summaries, and action items. Open-source Tactiq alternative.",
  "default_locale": "en",
  "icons": {
    "16": "public/icon16.png",
    "48": "public/icon48.png",
    "128": "public/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://zoom.us/*",
    "https://teams.microsoft.com/*",
    "https://*.openai.com/*",
    "https://*.anthropic.com/*"
  ],
  "side_panel": {
    "default_path": "src/panel/panel.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content/meet-captions.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://zoom.us/*", "https://*.zoom.us/*", "https://zoom.us/*"],
      "js": ["src/content/zoom-captions.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://teams.microsoft.com/*", "https://*.teams.microsoft.com/*"],
      "js": ["src/content/teams-captions.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
    "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline'"
  },
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "MeetScribe",
    "default_icon": {
      "16": "public/icon16.png",
      "48": "public/icon48.png",
      "128": "public/icon128.png"
    }
  }
}
